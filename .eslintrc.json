{
  "extends": ["eslint:recommended", "plugin:import/recommended", "plugin:import/typescript", "plugin:@typescript-eslint/recommended", "prettier"],
  "env": {
    "browser": true,
    "es6": true
  },
  "settings": {
    "import/parsers": {
      "@typescript-eslint/parser": [".ts", ".tsx", ".js", ".jsx"]
    },
    "import/resolver": {
      "typescript": {
        "alwaysTryTypes": true,
        "extensionAlias": {
          ".js": [ ".ts", ".tsx", ".js", ".jsx"],
          ".jsx": [ ".ts", ".tsx", ".js", ".jsx"],
          ".ts": [".ts", ".tsx", ".js", ".jsx"],
          ".tsx": [".ts", ".tsx", ".js", ".jsx"]
        },
        "extensions": [".ts", ".tsx", ".js", ".jsx"]
      },
      "node": true
    }
  },
  "plugins": ["@typescript-eslint"],
  "rules": {
    "@typescript-eslint/ban-types": ["warn"],
    "@typescript-eslint/naming-convention": [
      "warn",
      {
        "selector": "default",
        "format": ["camelCase", "PascalCase"]
      },
      {
        "selector": "variable",
        "format": ["camelCase", "UPPER_CASE"]
      },
      {
        "selector": "property",
        "format": ["camelCase", "UPPER_CASE"]
      },
      {
        "selector": "typeLike",
        "format": ["PascalCase"]
      },
      {
        "selector": "enumMember",
        "format": ["UPPER_CASE"]
      },
      {
        "selector": "parameter",
        "format": ["camelCase"],
        "leadingUnderscore": "allow"
      }
    ],
    "@typescript-eslint/indent": ["off"],
    "@typescript-eslint/no-empty-function": ["warn"],
    "@typescript-eslint/no-inferrable-types": ["warn"],
    "@typescript-eslint/no-this-alias": ["warn"],
    "prefer-const": ["warn"],
    "prefer-spread": ["warn"],
    "import/extensions": [
      "error",
      "ignorePackages",
      {
        "js": "always",
        "mjs": "always",
        "jsx": "always",
        "ts": "never",
        "tsx": "never"
      }
    ],
    "no-var": ["warn"],
    // note you must disable the base rule as it can report incorrect errors
    "no-unused-vars": "off",
    "@typescript-eslint/no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }],
    // Check for relative imports that are missing a file extension.
    "no-restricted-syntax": [
      "error",
      {
        // Breakdown of the regex:
        // 1. ^..?/ => checks for ./ or ../ at start of path
        // 2. ([\w]+/)* => any additional paths (word characters + slashes) between the start and final file name
        // 3. [\w]+$ => a final file name that has no file extension (`.` character missing)
        // The below regex is escaped (\\x2f for /, \\. for ., etc.) for parsing.
        "selector": "ImportDeclaration[source.value=/^\\.\\.?\\x2f([\\w]+\\x2f)*[\\w]+$/]",
        "message": "Relative imports/exports must include a file extension (use .js for TS/JS modules)."
      }
    ]
  },
  // Disable checks for import file extensions in test and worker files.
  "overrides": [
    {
      "files": ["src/test/**/*", "src/workers/**/*"],
      "rules": {
        "no-restricted-syntax": "off"
      }
    }
  ]
}
